{
    "compilerOptions": {
        "target": "ES2020",
        "module": "node16",
        "lib": [
            "ES2020"
        ],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "moduleResolution": "node16",
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "paths": {
            "@config/*": [
                "./src/config/*"
            ],
            "@controllers/*": [
                "./src/controllers/*"
            ],
            "@middlewares/*": [
                "./src/middlewares/*"
            ],
            "@models/*": [
                "./src/models/*"
            ],
            "@routes/*": [
                "./src/routes/*"
            ],
            "@services/*": [
                "./src/services/*"
            ],
            "@utils/*": [
                "./src/utils/*"
            ],
            "@validators/*": [
                "./src/validators/*"
            ],
            "@types/*": [
                "./src/types/*"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}